DATABASE_URL=postgres://cam_blindspot:cam_blindspot@localhost:5432/cam_blindspot
PORT=8000
APP_PORT=8000
DB_PORT=5432
OVERPASS_URL=https://overpass-api.de/api/interpreter
# Tile server URL (Cesium UrlTemplateImageryProvider format with {z}/{x}/{y} placeholders)
# Option A: External tile server
TILE_SERVER_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
# Option B: Docker tile server (overv/openstreetmap-tile-server with profile "tileserver")
# TILE_SERVER_URL=http://localhost:8080/tile/{z}/{x}/{y}.png
TILESERVER_PORT=8080
DJANGO_SETTINGS_MODULE=cam_blindspot.settings
DEBUG=true
SECRET_KEY=django-insecure-dev-only-cam-blindspot
